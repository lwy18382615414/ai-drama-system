TEXT_PROVIDER_BASE_URL=https://lv-ai-assistant.xyz:8444/v1
TEXT_PROVIDER_API_KEY=
TEXT_PROVIDER_MODEL=gpt-5.5

IMAGE_PROVIDER_BASE_URL=https://lv-ai-assistant.xyz:8444/v1
IMAGE_PROVIDER_API_KEY=
IMAGE_PROVIDER_MODEL=doubao-seedream-5-0-260128
# doubao-seedream 用 size 档位（2K）而非像素尺寸；模型名含 seedream 时会自动切换，这里显式声明更稳妥。
IMAGE_PROVIDER_SIZE_MODE=tier

# How the `size` param is expressed: `pixels` (gpt-image, e.g. 1024x1024) or
# `tier` (Volcengine Ark Seedream, e.g. 2K). Optional; auto-detected from the
# model name (models matching /seedream|seededit/ default to `tier`).
# IMAGE_PROVIDER_SIZE_MODE=tier

# Resolution tier when SIZE_MODE=tier: 1K | 2K | 4K. Lower tiers generate much
# faster (model inference dominates latency). Optional; defaults to 2K.
# IMAGE_PROVIDER_SIZE_TIER=2K

# Max generation tasks (incl. storyboard frames) running concurrently. Main lever
# for batch image throughput. Optional; defaults to 2.
# TASK_WORKER_CONCURRENCY=4

# Directory where generated images are written and served under /static.
# Optional; defaults to data/static.
# STATIC_DIR=data/static
