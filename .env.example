# ── 文本 Provider（OpenAI 兼容）───────────────────────────────
TEXT_PROVIDER_BASE_URL=https://lv-ai-assistant.xyz:8444/v1
TEXT_PROVIDER_API_KEY=
TEXT_PROVIDER_MODEL=gpt-5.5

# ── 图像 Provider（OpenAI 兼容）───────────────────────────────
IMAGE_PROVIDER_BASE_URL=https://lv-ai-assistant.xyz:8444/v1
IMAGE_PROVIDER_API_KEY=
# 图像模型。示例为 Gemini 图像（nano banana），走 chat 通道；
# 若用 Seedream 改为 doubao-seedream-5-0-260128 并配下方的 SIZE 档位。
IMAGE_PROVIDER_MODEL=gemini-3.1-flash-image

# 到达图像模型的传输方式：
#   images —— OpenAI images 端点（gpt-image / Seedream）
#   chat   —— 图片从 chat 响应的 message.images[] 返回（Gemini nano banana，如 gemini-3.1-flash-image）
# 可选；默认按模型名自动识别（匹配 /gemini.*image|flash-image|nano.?banana/ 走 chat）。
# chat 模式下 SIZE_MODE / SIZE_TIER 会被忽略（Gemini 按提示词自行决定宽高比）。
# IMAGE_PROVIDER_TRANSPORT=chat

# size 参数的表达方式：
#   pixels —— 固定像素（gpt-image，如 1024x1024）
#   tier   —— 分辨率档位（火山方舟 Seedream，如 2K）
# 可选；默认按模型名自动识别（匹配 /seedream|seededit/ 用 tier）。仅在 images 传输下生效。
# IMAGE_PROVIDER_SIZE_MODE=tier

# SIZE_MODE=tier 时的分辨率档位：1K | 2K | 4K。
# 档位越低生成越快（延迟主要来自模型推理）。可选；默认 2K。
# IMAGE_PROVIDER_SIZE_TIER=2K

# ── 任务与存储 ────────────────────────────────────────────────
# 并发生成任务数（含分镜首帧）。批量出图吞吐的主要调节项。可选；默认 2。
# TASK_WORKER_CONCURRENCY=4

# 生成图片的写入目录，并在 /static 下对外提供。可选；默认 data/static。
# STATIC_DIR=data/static
